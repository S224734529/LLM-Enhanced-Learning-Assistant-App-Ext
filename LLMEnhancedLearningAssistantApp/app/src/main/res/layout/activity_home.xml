<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/helloText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hello,\nYour Name"
        android:textColor="@color/dark_text"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/taskDueText"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="@drawable/chip_bg"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:text="You have 1 task due"
        android:textColor="@color/dark_text"
        android:textStyle="bold"
        android:layout_marginTop="12dp" />

    <LinearLayout
        android:id="@+id/taskCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:background="@drawable/card_blue"
        android:clickable="true"
        android:contentDescription="Open generated task one"
        android:focusable="true"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✨"
            android:textSize="18sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Generated Task 1"
            android:textColor="@color/white"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Small Description for the generated Task"
            android:textColor="@color/white"
            android:textSize="14sp" />

        <Button
            android:layout_width="70dp"
            android:layout_height="38dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/button_green"
            android:text="Go"
            android:textColor="@color/dark_text" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/profileButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/button_green"
        android:text="Profile"
        android:textColor="@color/dark_text"
        android:textStyle="bold" />

    <Button
        android:id="@+id/historyButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/button_green"
        android:text="History"
        android:textColor="@color/dark_text"
        android:textStyle="bold" />

    <Button
        android:id="@+id/upgradeButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/button_green"
        android:text="Upgrade Account"
        android:textColor="@color/dark_text"
        android:textStyle="bold" />

</LinearLayout>