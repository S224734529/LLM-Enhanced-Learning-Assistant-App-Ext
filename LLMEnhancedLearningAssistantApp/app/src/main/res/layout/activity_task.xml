<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/generatedByText"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:background="@drawable/chip_bg"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:text="✦ Generated by AI"
            android:textColor="@color/dark_text"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Generated Task 1"
            android:textColor="@color/dark_text"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/promptText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Prompt will appear here"
            android:textColor="@color/dark_text"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/questionOneGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/card_blue"
            android:padding="14dp">

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="1. Question 1" android:textColor="@color/white" android:textStyle="bold" />
            <TextView android:id="@+id/questionOneText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Which of the following is a type of cloud computing service?." android:textColor="@color/white" />
            <RadioButton android:id="@+id/answerOne" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Service-as-a-Software (SaaS)" android:textColor="@color/white" />
            <RadioButton android:id="@+id/answerTwo" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Software-as-a-Service (SaaS)" android:textColor="@color/white" />
            <RadioButton android:id="@+id/answerThree" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Software-as-a-Server (SaaS)" android:textColor="@color/white" />
        </RadioGroup>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/card_blue"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView android:id="@+id/questionTwoText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="2. Question 2" android:textColor="@color/white" android:textStyle="bold" />
            <EditText android:id="@+id/writtenAnswerInput" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="8dp" android:hint="Write your answer" android:background="@drawable/input_box" />
        </LinearLayout>

        <Button
            android:id="@+id/hintButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/button_green"
            android:text="Generate Hint"
            android:textColor="@color/dark_text"
            android:textStyle="bold" />

        <Button
            android:id="@+id/summaryButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/button_green"
            android:text="Create 3 Flashcards"
            android:textColor="@color/dark_text"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/aiResponseText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="80dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/chip_bg"
            android:padding="12dp"
            android:text="AI prompt and response will appear here."
            android:textColor="@color/dark_text"
            android:textSize="15sp" />

        <ProgressBar
            android:id="@+id/loadingBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:visibility="gone" />

        <Button
            android:id="@+id/submitButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/button_green"
            android:text="Submit"
            android:textColor="@color/dark_text"
            android:textStyle="bold" />

        <Button
            android:id="@+id/profileButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/button_green"
            android:text="Profile"
            android:textColor="@color/dark_text"
            android:textStyle="bold" />

        <Button
            android:id="@+id/historyButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/button_green"
            android:text="History"
            android:textColor="@color/dark_text"
            android:textStyle="bold" />

        <Button
            android:id="@+id/upgradeButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/button_green"
            android:text="Upgrade Account"
            android:textColor="@color/dark_text"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>